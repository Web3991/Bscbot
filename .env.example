# BSC bot environment template
# Copy to .env and fill with real secrets before running.

# Required: Telegram bot token for control plane + alerts
TELEGRAM_BOT_TOKEN=123456:replace_me

# Required: Telegram chat id that should receive startup alerts and commands
# Example: private chat user id or a group/channel id (can be negative)
TELEGRAM_CHAT_ID=123456789

# Required: wallet private key for on-chain execution
# Do NOT commit the real value.
BSC_PRIVATE_KEY=0xreplace_me

# Optional: Grok API key for narrative scoring
GROK_API_KEY=

# Optional: one proxy or comma-separated proxies for Grok/http access
GROK_PROXY=
GROK_PROXIES=

# Optional: safety switch for simulation mode
# true  -> dry run / paper mode
# false -> live trading mode
DRY_RUN=true
